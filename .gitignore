# Example run outputs. Keep directories in the tree, ignore their generated contents.
examples/out/*
!examples/out/.gitkeep
examples/nanogpt/out/*
!examples/nanogpt/out/.gitkeep
examples/whisper_audio/out/*
!examples/whisper_audio/out/.gitkeep
